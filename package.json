{
  "name": "erc20-hardhat",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "compile": "npx hardhat compile --network reef",
    "deploy": "npx hardhat run scripts/deploy.js --network localNode",
    "deploy:verify": "npx hardhat run scripts/deploy_and_verify.js --network reef",
    "deploy:reefswap": "npx hardhat run scripts/deploy_reefswap.js --network localNode",
    "deploy:token": "npx hardhat run scripts/deploy_token.js --network localNode",
    "deploy:reef-erc20": "npx hardhat run scripts/deploy_reef_erc20.js --network localNode",
    "reef:info": "node scripts/reef_erc20_info.js",
    "reef:balance": "node scripts/reef_erc20_balance.js",
    "reef:transfer": "node scripts/reef_erc20_transfer.js",
    "reef:approve": "node scripts/reef_erc20_approve.js",
    "reef:allowance": "node scripts/reef_erc20_allowance.js",
    "reef:transfer-from": "node scripts/reef_erc20_transfer_from.js",
    "reef:state-dump": "node scripts/reef_erc20_state_dump.js",
    "reef:write-probe": "node scripts/reef_erc20_write_probe.js",
    "reef:all": "node scripts/reef_erc20_all.js",
    "seed:reefswap": "npx hardhat run scripts/bootstrap_reefswap_activity.js --network localNode",
    "seed:reefswap:full": "npx hardhat run scripts/bootstrap_reefswap_full.js --network localNode",
    "test:create2": "npx hardhat test test/Create2Factory.js --network hardhat",
    "compile:create2:remote": "npx hardhat compile --force --network localhost8545",
    "deploy:create2:remote": "npm run compile:create2:remote && node scripts/deploy_and_test_create2_remote.js",
    "test:reefswap:deep": "npx hardhat test test/reefswap/Reefswap.deep.test.js --network hardhat",
    "test:reefswap:deep:localhost": "HARDHAT_FORK_URL=http://127.0.0.1:8545 npx hardhat test test/reefswap/Reefswap.deep.test.js --network hardhat",
    "test:reefswap": "npx hardhat test test/reefswap/Reefswap.localhost.test.js --network localhost",
    "test:reefswap:addresses:localhost": "npx hardhat test test/reefswap/Reefswap.localhost.addresses.test.js --network localhost"
  },
  "keywords": [],
  "author": "@anukulpandey",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "devDependencies": {
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "chai": "^4.2.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "typechain": "^8.3.0",
    "@parity/hardhat-polkadot": "^0.2.7",
    "dotenv": "^16.5.0",
    "solc": "0.8.28"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "axios": "^1.12.2"
  }
